{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.test.ts", "**/tests/**/*.test.ts"],
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js",
    "^.*/services/geminiService$": "<rootDir>/src/__tests__/integration/__mocks__/geminiService.js"
  },
  "projects": [
    {
      "displayName": "unit",
      "preset": "ts-jest",
      "testEnvironment": "node",
      "roots": ["<rootDir>/src"],
      "testMatch": ["**/__tests__/*.test.ts", "**/tests/**/*.test.ts"],
      "moduleNameMapper": {
        "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js",
        "^.*/services/geminiService$": "<rootDir>/src/__tests__/integration/__mocks__/geminiService.js"
      }
    },
    {
      "displayName": "e2e",
      "preset": "ts-jest",
      "testEnvironment": "node",
      "roots": ["<rootDir>/src"],
      "testMatch": ["**/__tests__/integration/*.e2e.test.ts"],
      "moduleNameMapper": {
        "^uuid$": "<rootDir>/src/__tests__/integration/__mocks__/uuid.js",
        "^.*/services/geminiService$": "<rootDir>/src/__tests__/integration/__mocks__/geminiService.js"
      },
      "transform": {
        "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
      },
      "testTimeout": 15000
    }
  ]
  "testMatch": [
    "**/__tests__/**/*.test.ts",
    "**/*.test.ts"
  ],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/server.ts",
    "!src/tracing.ts"
  ],
  "coverageReporters": ["text", "lcov", "html"],
  "coverageDirectory": "coverage",
  "coverageThreshold": {
    "global": {
      "lines": 50
    }
  }
}
